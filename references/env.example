# .env.local template for a super brain project.
#
# /super-setup copies this file to <project>/.env.local on first run (only if
# .env.local is missing — it never overwrites). Fill in the secrets below and
# keep .env.local out of git (it is gitignored by default).
#
# Enable only the sources you actually use in <project>/.super/brain.config.yml
# under `sources.<name>.enabled`; unused vars below can stay blank.

# ─── ClickUp ──────────────────────────────────────────────────────────────────
# Get from ClickUp → Settings → Apps → API Token → "Generate"
CLICKUP_TOKEN=

# ─── Confluence (Atlassian) ───────────────────────────────────────────────────
# Get an API token from https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_EMAIL=
CONFLUENCE_BASE_URL=https://<your-org>.atlassian.net/wiki
CONFLUENCE_API=/rest/api/content
CONFLUENCE_TOKEN=

# ─── Linear ───────────────────────────────────────────────────────────────────
# Get from https://linear.app/settings/api → "Personal API keys" → "Create new key"
LINEAR_TOKEN=
# Optional: a semicolon-separated list of Linear project URLs used by
# brain-linear-process-ideas / brain-linear-process-tasks when no URL argument
# is provided. Example:
#   LINEAR_LOOP=https://linear.app/<org>/project/foo-abc/issues;https://linear.app/<org>/project/bar-def/issues;
LINEAR_LOOP=

# ─── GitHub ───────────────────────────────────────────────────────────────────
# Personal access token with `repo` scope (classic) or equivalent fine-grained
# permissions, used by the github pull utilities to clone private repos.
GITHUB_TOKEN=

# ─── Google Cloud (BigQuery MCP, analytics skills) ────────────────────────────
# First run: `gcloud auth application-default login`
GCP_PROJECT_ID=<your-gcp-project>

# ─── Metabase ─────────────────────────────────────────────────────────────────
# Get an API key from Metabase → Admin settings → Authentication → API keys
# (or use email+password as a fallback).
METABASE_URL=https://metabase.<your-org>.com
METABASE_API_KEY=
# Fallback auth (used only if METABASE_API_KEY is empty):
METABASE_USER_EMAIL=
METABASE_PASSWORD=

# ─── Medium (optional) ────────────────────────────────────────────────────────
# Used by the Medium export — no token needed, but you can set the handle here
# to document whose blog you're pulling.
# MEDIUM_HANDLE=<your-handle>
