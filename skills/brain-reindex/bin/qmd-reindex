#!/usr/bin/env bash
set -euo pipefail

# qmd-reindex — write qmd config and rebuild the brain index for the current project
# Usage: qmd-reindex
#
# The "brain" is the project root: the dir containing .super/. Found by walking up
# from $SUPER_PROJECT_DIR (or cwd). Reads <project>/.super/brain.config.yml for
# org/role values, writes ~/.config/qmd/index.yml covering agents/memory/outputs/src,
# then runs `qmd update` + `qmd embed`.
# First run downloads ~2GB of GGUF embedding models.

# ─── Locate project root (the .super-bearing dir is the brain) ─────────────────
# The `.super/` match must be a real dir. `<project>/.super/.super` is a debug
# symlink to ~/.super and must not be treated as a project root.
#
# Guardrails against misrooting to $HOME:
#   1. Stop the walk before reaching $HOME. $HOME/.super is the global super
#      install, never a project root. Without this, running qmd-reindex from
#      any directory that isn't under a brain would walk up past its parents,
#      hit $HOME, and start creating agents/memory/outputs/src at the top of
#      the user's home directory.
#   2. Additionally skip any `.super/` whose realpath equals the realpath of
#      $HOME/.super, catching the debug symlink `<project>/.super/.super` and
#      any other alias of the global install.
find_super_project() {
  local dir="${SUPER_PROJECT_DIR:-$(pwd)}"
  local home="${HOME:-}"
  local global_super=""
  if [[ -n "$home" && -d "$home/.super" ]]; then
    # realpath may be unavailable on some systems; fall back to `cd && pwd -P`
    global_super="$(cd "$home/.super" 2>/dev/null && pwd -P)" || global_super=""
  fi
  while [[ -n "$dir" && "$dir" != "/" ]]; do
    if [[ -n "$home" && "$dir" == "$home" ]]; then
      return 1 # never treat $HOME as a project root
    fi
    if [[ -d "$dir/.super" && ! -L "$dir/.super" ]]; then
      local candidate_real="$(cd "$dir/.super" 2>/dev/null && pwd -P)" || candidate_real=""
      if [[ -n "$candidate_real" && -n "$global_super" && "$candidate_real" == "$global_super" ]]; then
        : # candidate resolves to the global install — skip
      else
        echo "$dir"; return 0
      fi
    fi
    dir="$(dirname "$dir")"
  done
  return 1
}

if ! BRAIN="$(find_super_project)"; then
  echo "No project .super/ directory found walking up from $(pwd)."
  echo "(\$HOME/.super is the global install, not a project — it is intentionally ignored.)"
  echo "Run 'super install' inside your brain project first, then '/super-setup'."
  exit 1
fi

if [[ -n "${HOME:-}" && "$BRAIN" == "$HOME" ]]; then
  echo "Refusing to reindex into \$HOME ($HOME)."
  echo "cd into your brain project and re-run qmd-reindex."
  exit 1
fi

BRAIN_CONFIG="${BRAIN_CONFIG:-${BRAIN}/.super/brain.config.yml}"

# ─── Read scalars from the project-local config (org name + role) ──────────────
yaml_scalar() {
  local key="$1" file="$2" section="${3:-}"
  if [ -n "$section" ]; then
    awk -v sect="$section" -v key="$key" '
      $0 ~ "^"sect":" { in_s=1; next }
      in_s && /^[^[:space:]]/ { in_s=0 }
      in_s && $0 ~ "^[[:space:]]+"key":" {
        sub("^[[:space:]]+"key":[[:space:]]*", "")
        gsub(/^["\x27]|["\x27]$/, "")
        print; exit
      }
    ' "$file"
  fi
}

if [ -f "${BRAIN_CONFIG}" ]; then
  CFG_ROLE="$(yaml_scalar role "${BRAIN_CONFIG}" organization)"
  CFG_ORG_NAME="$(yaml_scalar name "${BRAIN_CONFIG}" organization)"
fi
ROLE="${CFG_ROLE:-brain owner}"
ORG_NAME="${CFG_ORG_NAME:-their org}"

if ! command -v qmd &>/dev/null; then
  echo "qmd not found — reinstall super (it installs qmd), or run: npm install -g @tobilu/qmd"
  exit 1
fi

# Ensure the 4 brain dirs exist so qmd doesn't error on empty paths.
for d in agents memory outputs src; do
  [ -d "${BRAIN}/${d}" ] || mkdir -p "${BRAIN}/${d}"
done

echo "Indexing brain at: ${BRAIN}"

mkdir -p "${HOME}/.config/qmd"
cat > "${HOME}/.config/qmd/index.yml" << EOF
globalContext: >
  This is the personal brain of ${ROLE}.
  Four top-level folders: agents/ (agent outputs), memory/ (curated knowledge — L1 navigation MOCs
  and L2 domain knowledge), outputs/ (service docs, agent reports, project workspaces),
  src/ (raw exports from ClickUp, Confluence, Google Drive, GitHub, Google Workspace, Linear,
  Medium, Metabase, and others). If you see a [[WikiWord]], search for that term to get more context.

collections:
  agents:
    path: ${BRAIN}/agents
    pattern: "**/*.md"
    contexts:
      "": "Agent outputs — ad-hoc agents operating on the brain (SEO, press, inbox triage, WorkFlowy, X.com, etc.)"

  memory:
    path: ${BRAIN}/memory
    pattern: "**/*.md"
    contexts:
      "L1/": "L1 navigation MOCs — high-level domain maps for teams, products, data, sources"
      "L2/": "L2 curated knowledge — teams, technologies, cross-references, executive docs"

  outputs:
    path: ${BRAIN}/outputs
    pattern: "**/*.{md,AGENT.MD}"
    contexts:
      "services/": "Per-service agent docs — stack, schema, messaging, auth, APIs"
      "agents/": "Agent time-series reports — monthly decks, meeting prep, audits"
      "projects/": "Project workspaces — ad-hoc investigations, analyses, research"

  src:
    path: ${BRAIN}/src
    pattern: "**/*.md"
    contexts:
      "clickup/": "ClickUp docs — team docs, wikis"
      "confluence/": "Confluence — intranet, wikis"
      "gdrive/": "Google Drive — one-pagers, ExCo docs, investor updates, team updates"
      "github/": "GitHub repos — source code docs, CLAUDE.md, AGENTS.md, READMEs"
      "gws/": "Google Workspace — Meet transcripts and meeting digests"
      "linear/": "Linear — project updates, issue tracking, team workflows"
      "medium/": "Medium — blog posts"
      "metabase/": "Metabase — dashboard and card index"

EOF

echo "✓ wrote ~/.config/qmd/index.yml"
echo "Scanning files..."
qmd update
echo "Building embeddings..."
qmd embed
echo "✓ qmd index ready"
