#!/bin/bash
# Google Drive to Markdown exporter wrapper
# Usage: gdrive_to_md <google_drive_folder_url>

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Find a Python interpreter that has markitdown installed
PYTHON="python3"

# 1. Check if python3 can import markitdown
if python3 -c "import markitdown" 2>/dev/null; then
    PYTHON="python3"
# 2. Check pipx venv python
elif [ -x "$HOME/.local/pipx/venvs/markitdown/bin/python" ]; then
    PYTHON="$HOME/.local/pipx/venvs/markitdown/bin/python"
# 3. Derive python from markitdown binary location
elif command -v markitdown >/dev/null 2>&1; then
    MARKITDOWN_BIN="$(command -v markitdown)"
    if [[ "$MARKITDOWN_BIN" == */bin/markitdown ]]; then
        VENV_PYTHON="${MARKITDOWN_BIN%/bin/markitdown}/bin/python"
        if [ -x "$VENV_PYTHON" ] && "$VENV_PYTHON" -c "import markitdown" 2>/dev/null; then
            PYTHON="$VENV_PYTHON"
        fi
    fi
fi

exec "$PYTHON" "$PROJECT_ROOT/utils/gdrive_to_md.py" "$@"
