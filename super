# ═══════════════════════════════════════════════════════════════════════════════
# SAVE COMMAND
# ═══════════════════════════════════════════════════════════════════════════════

cmd_save() {
  local note="${1:-}"
  local session_file; session_file="$(_super_session_file)"
  
  [[ -z "$session_file" || ! -f "$session_file" ]] && die "No active session. Start one with: super launch <cli>"
  
  local ts; ts="$(date '+%Y-%m-%d %H:%M:%S')"
  printf '\n---\n\n## 💾 Manual Save `[%s]`\n\n' "$ts" >> "$session_file"
  
  [[ -n "$note" ]] && printf '> **Note:** %s\n\n' "$note" >> "$session_file"
  
  local turns; turns="$(grep -c '^## ' "$session_file" 2>/dev/null || echo 0)"
  
  ui_msg_checkpoint
  ui_muted "  $(basename "$session_file") — $turns turns"
  
  if _super_config_enabled "session.transcriptLog"; then
    session_save_transcript
  fi
}

# ═══════════════════════════════════════════════════════════════════════════════
# CATCHUP COMMAND
# ═══════════════════════════════════════════════════════════════════════════════

cmd_catchup() {
  local session_file="${SUPER_SESSION_FILE:-$(_super_session_file)}"
  
  [[ -z "$session_file" || ! -f "$session_file" ]] && {
    ui_warn "No active session."
    ui_muted "Start one with: super launch <cli>"
    return 1
  }
  
  ui_spacer
  ui_print "  $(ui_bold "📋 Session Catchup")"
  ui_spacer
  
  local basename turns last_save
  basename="$(basename "$session_file")"
  turns="$(grep -c '^## ' "$session_file" 2>/dev/null || echo 0)"
  last_save="$(grep -E '^## 💾 Manual Save' "$session_file" | tail -1 | sed 's/.*\[\(.*\)\].*/\1/')"
  
  ui_print "  Session: $(ui_bold "$basename")"
  ui_print "  Turns: $turns"
  [[ -n "$last_save" ]] && ui_print "  Last save: $last_save"
  ui_spacer
  
  ui_print "  $(_c $UI_MUTED)Recent activity:${UI_RESET}"
  ui_spacer
  
  # Recent turns with context
  grep -E '^## .*User|^### .*Assistant' "$session_file" | tail -10 | while read -r line; do
    if [[ "$line" == *"User"* ]]; then
      local content; content="$(echo "$line" | sed 's/.*User//' | head -c 60)"
      [[ ${#content} -eq 60 ]] && content="${content}..."
      ui_print "    $(_c $UI_MUTED)•${UI_RESET} 👤 $content"
    fi
  done
  
  ui_spacer
  ui_muted "Use 'super log' for full session"
  ui_spacer
}

# ═══════════════════════════════════════════════════════════════════════════════
# QUICK SHORTCUTS
# ═══════════════════════════════════════════════════════════════════════════════

cmd_quick_active() {
  # @ shortcut — jump to active session
  local active; active="$(_super_session_file)"
  [[ -z "$active" || ! -f "$active" ]] && die "No active session"
  
  local last_cli; last_cli="$(detect_last_cli)"
  [[ -z "$last_cli" ]] && die "Cannot detect last CLI used"
  
  cmd_launch "$last_cli" --resume
}

cmd_quick_new() {
  # ! shortcut — new session, skip picker
  _pick_cli_and_launch
}

cmd_quick_search() {
  # ? shortcut — fuzzy search all sessions
  local picked; picked="$(fzf_pick_session)"
  [[ "$picked" == "QUIT" || -z "$picked" || "$picked" == "NEW" ]] && return
  cmd_resume "$picked"
}

# ═══════════════════════════════════════════════════════════════════════════════
# HELP COMMAND
# ═══════════════════════════════════════════════════════════════════════════════

cmd_help() {
  print_banner
  cat << 'HELPEOF'
USAGE
  super [command] [args]

QUICK SHORTCUTS
  super                      Main menu (with fzf if available)
  super @                    Jump to active session
  super !                    New session, pick CLI
  super ?                    Fuzzy search all sessions
  super <cli>                Direct launch (claude|gemini|codex|kimi)

COMMANDS
  install [--interactive|-i] [all|claude|gemini|codex|kimi]
      Install hooks and context files
      --interactive   Use checkbox UI to select CLIs (default if no target)
      (Uses gum if available, otherwise pure bash checkboxes)

  launch <cli> [--title <name>] [--resume [file]]
      Start a new session

  resume [file]
      Resume a session (with fzf picker)

  sessions
      List all sessions

  switch <cli>
      Switch active session to different CLI

  log [N | file.md]
      View session (last N turns or specific file)

  doctor
      Run health check on super installation

  clean
      Remove context injections

  uninstall
      Remove super hooks

  status
      Show status with recent activity

  config [show|init|edit]
      Manage configuration

  validate
      Run project validators

  cleanup [days]
      Remove old sessions

  transcript [list|save]
      Manage transcripts

  save [note]
      Save checkpoint to session

  catchup
      Show session summary

  help
      Show this help

EXAMPLES
  super claude                    # New Claude session
  super claude --resume           # Resume with fzf picker
  super gemini --title "fix auth" # Named session
  super switch gemini             # Continue in Gemini
  super @                         # Jump to active session
  super doctor                    # Health check

SESSION FILES
  .super/sessions/<timestamp>_<title>.md
  Active session tracked in .super/active
HELPEOF
}

# ═══════════════════════════════════════════════════════════════════════════════
# MAIN DISPATCH
# ═══════════════════════════════════════════════════════════════════════════════

main() {
  # Handle quick shortcuts first
  case "${1:-menu}" in
    @) cmd_quick_active; exit $? ;;
    !) cmd_quick_new; exit $? ;;
    \?) cmd_quick_search; exit $? ;;
  esac
  
  local cmd="${1:-menu}"
  shift || true
  
  case "$cmd" in
    install|i)         cmd_install "$@" ;;
    launch|l|run)      cmd_launch "$@" ;;
    resume|r)          cmd_resume "$@" ;;
    sessions|ls|list)  cmd_sessions ;;
    switch|sw)         cmd_switch "$@" ;;
    log|show)          cmd_log "$@" ;;
    doctor|dr)         cmd_doctor ;;
    clean)             cmd_clean ;;
    uninstall)         cmd_uninstall ;;
    status|s)          print_banner; print_status ;;
    config|cfg)        cmd_config "$@" ;;
    validate|lint)     cmd_validate ;;
    cleanup)           cmd_cleanup "$@" ;;
    transcript|trans)  cmd_transcript "$@" ;;
    save)              cmd_save "$@" ;;
    catchup|c)         cmd_catchup ;;
    --version|-v)      echo "super v$SUPER_VERSION"; exit 0 ;;
    help|--help|-h)    cmd_help ;;
    menu)              cmd_menu ;;
    claude|gemini|codex|kimi) cmd_launch "$cmd" "$@" ;;
    *) die "Unknown command: $cmd. Run: super help" ;;
  esac
}

main "$@"
