#!/usr/bin/env bash
# ╔══════════════════════════════════════════════════════════════════╗
# ║  super v1.1  — cross-CLI session bridge                      ║
# ║  Claude Code · Gemini CLI · Codex CLI · Kimi Code CLI           ║
# ╚══════════════════════════════════════════════════════════════════╝

# Handle --version before anything else (works even on bash 3)
if [[ "${1:-}" == "--version" || "${1:-}" == "-v" ]]; then
  cat "$(dirname "${BASH_SOURCE[0]}")/VERSION" 2>/dev/null || echo "unknown"
  exit 0
fi

# Bash version check (before associative arrays)
if [[ "${BASH_VERSINFO[0]}" -lt 4 ]]; then
  echo "error: super requires bash 4+. You have $BASH_VERSION" >&2
  echo "Install with: brew install bash" >&2
  exit 1
fi

set -euo pipefail

SUPER_HOME="${SUPER_HOME:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"
export SUPER_HOME
SUPER_VERSION="$(cat "$SUPER_HOME/VERSION" 2>/dev/null || echo "unknown")"

source "$SUPER_HOME/lib/session.sh"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; DIM='\033[2m'; RESET='\033[0m'

declare -A CLI_CMD=(   [claude]="claude" [gemini]="gemini" [codex]="codex" [kimi]="kimi" )
declare -A CLI_ICON=(  [claude]="🟠"     [gemini]="🔵"     [codex]="🟢"    [kimi]="🟡"  )
declare -A CLI_LABEL=( [claude]="Claude Code" [gemini]="Gemini CLI" [codex]="Codex CLI" [kimi]="Kimi Code CLI" )
declare -A CLI_CTX=(   [claude]="CLAUDE.md"   [gemini]="GEMINI.md"  [codex]="AGENTS.md" [kimi]="AGENTS.md"    )

die()  { echo -e "${RED}error:${RESET} $*" >&2; exit 1; }
info() { echo -e "${CYAN}super:${RESET} $*"; }
ok()   { echo -e "${GREEN}✓${RESET} $*"; }
warn() { echo -e "${YELLOW}warning:${RESET} $*"; }
is_installed() { command -v "${CLI_CMD[$1]}" &>/dev/null; }

print_banner() {
  echo -e "${BOLD}"
  echo "  ╭──────────────────────────────────────────╮"
  echo "  │  🔀  super v${SUPER_VERSION}                   │"
  echo "  │  Cross-CLI session bridge                │"
  echo "  ╰──────────────────────────────────────────╯"
  echo -e "${RESET}"
}

print_status() {
  echo ""
  echo -e "${BOLD}CLIs:${RESET}"
  for cli in claude gemini codex kimi; do
    local icon="${CLI_ICON[$cli]}" label="${CLI_LABEL[$cli]}"
    if is_installed "$cli"; then
      echo -e "  $icon  ${GREEN}${label}${RESET}  ${DIM}$(command -v "${CLI_CMD[$cli]}")${RESET}"
    else
      echo -e "  $icon  ${RED}${label}${RESET}  ${DIM}(not installed)${RESET}"
    fi
  done
  echo ""
  local sessions_dir; sessions_dir="$(_super_sessions_dir)"
  local active; active="$(_super_session_file)"
  echo -e "${BOLD}Sessions:${RESET}  ${DIM}$sessions_dir${RESET}"
  if [[ -d "$sessions_dir" ]]; then
    local count; count="$(ls "$sessions_dir"/*.md 2>/dev/null | wc -l | tr -d ' ')"
    echo -e "  $count session(s) on disk"
    if [[ -n "$active" && -f "$active" ]]; then
      local turns; turns="$(grep -c '^## ' "$active" 2>/dev/null || echo 0)"
      echo -e "  ${GREEN}Active:${RESET} $(basename "$active")  ${DIM}($turns turns)${RESET}"
    fi
  else
    echo -e "  ${YELLOW}No sessions yet.${RESET} Run: ${BOLD}super install${RESET}"
  fi
  echo ""
}

# ─── Hooks installation ───────────────────────────────────────────────────────

_merge_json_hooks() {
  local file="$1" new_json="$2" id_field="$3"
  python3 - "$file" "$new_json" "$id_field" <<'PYEOF'
import sys, json
path, new_json, idf = sys.argv[1], sys.argv[2], sys.argv[3]
with open(path) as f: existing = json.load(f)
new_hooks = json.loads(new_json).get("hooks", {})
if "hooks" not in existing: existing["hooks"] = {}
for event, defs in new_hooks.items():
    if event not in existing["hooks"]:
        existing["hooks"][event] = defs
    else:
        present = [h.get(idf,"") for grp in existing["hooks"][event]
                   for h in grp.get("hooks",[])]
        if not any("super" in p for p in present):
            existing["hooks"][event].extend(defs)
with open(path,"w") as f: json.dump(existing,f,indent=2); f.write("\n")
PYEOF
}

install_hooks_claude() {
  local root; root="$(_super_find_root)"
  local dir="$root/.claude"; mkdir -p "$dir"
  local settings="$dir/settings.json"
  local expanded; expanded="$(SUPER_HOME="$SUPER_HOME" envsubst \
    < "$SUPER_HOME/hooks/claude/settings.json.template")"
  if [[ -f "$settings" ]]; then _merge_json_hooks "$settings" "$expanded" "command"; ok "Updated $settings"
  else echo "$expanded" > "$settings"; ok "Created $settings"; fi
  chmod +x "$SUPER_HOME"/hooks/claude/*.sh
}

install_hooks_gemini() {
  local root; root="$(_super_find_root)"
  local dir="$root/.gemini"; mkdir -p "$dir"
  local settings="$dir/settings.json"
  local expanded; expanded="$(SUPER_HOME="$SUPER_HOME" envsubst \
    < "$SUPER_HOME/hooks/gemini/settings.json.template")"
  if [[ -f "$settings" ]]; then _merge_json_hooks "$settings" "$expanded" "name"; ok "Updated $settings"
  else echo "$expanded" > "$settings"; ok "Created $settings"; fi
  chmod +x "$SUPER_HOME"/hooks/gemini/*.sh
}

install_hooks_codex() {
  local root; root="$(_super_find_root)"
  local dir="$root/.codex"; mkdir -p "$dir"
  local hf="$dir/hooks.json"
  local expanded; expanded="$(SUPER_HOME="$SUPER_HOME" envsubst \
    < "$SUPER_HOME/hooks/codex/hooks.json.template")"
  if [[ -f "$hf" ]]; then _merge_json_hooks "$hf" "$expanded" "command"; ok "Updated $hf"
  else echo "$expanded" > "$hf"; ok "Created $hf"; fi
  chmod +x "$SUPER_HOME"/hooks/codex/*.sh
}

install_hooks_kimi() {
  local root; root="$(_super_find_root)"
  local cfg="$root/.kimi/config.toml"; mkdir -p "$(dirname "$cfg")"
  local expanded; expanded="$(SUPER_HOME="$SUPER_HOME" envsubst \
    < "$SUPER_HOME/hooks/kimi/config.toml.template")"
  if [[ -f "$cfg" ]]; then
    if grep -q "super" "$cfg" 2>/dev/null; then warn "super already in $cfg — skipping"
    else printf '\n# super hooks\n%s\n' "$expanded" >> "$cfg"; ok "Updated $cfg"; fi
  else
    printf '# Kimi config\n# super hooks\n%s\n' "$expanded" > "$cfg"; ok "Created $cfg"
  fi
  chmod +x "$SUPER_HOME"/hooks/kimi/*.sh
}

cmd_install() {
  local target="${1:-all}"
  info "Installing hooks (target: $target)"
  echo ""
  case "$target" in
    all)    install_hooks_claude; install_hooks_gemini
            install_hooks_codex;  install_hooks_kimi ;;
    claude) install_hooks_claude ;;
    gemini) install_hooks_gemini ;;
    codex)  install_hooks_codex  ;;
    kimi)   install_hooks_kimi   ;;
    *) die "Unknown CLI: $target. Use: all|claude|gemini|codex|kimi" ;;
  esac
  mkdir -p "$(_super_sessions_dir)"
  echo ""
  ok "Sessions folder ready: $(_super_sessions_dir)"
  info "Run ${BOLD}super launch <cli>${RESET} to start your first session"
}

# ─── Launch ───────────────────────────────────────────────────────────────────

cmd_launch() {
  local cli="${1:-}"
  shift || true

  local do_resume=0 resume_file="" title=""
  local passthrough=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --resume|-r)
        do_resume=1; shift
        if [[ $# -gt 0 && "${1:-}" != --* && "${1:-}" != -* ]]; then
          resume_file="$1"; shift
        fi ;;
      --title|-t) shift; title="${1:-}"; shift ;;
      *) passthrough+=("$1"); shift ;;
    esac
  done

  [[ -z "$cli" ]] && { cmd_menu; return; }
  cli="${cli,,}"
  [[ -z "${CLI_CMD[$cli]+_}" ]] && die "Unknown CLI: $cli"
  is_installed "$cli" || die "${CLI_LABEL[$cli]} is not installed"

  local session_file

  if [[ -n "$resume_file" ]]; then
    [[ -f "$resume_file" ]] || resume_file="$(_super_sessions_dir)/$resume_file"
    session_file="$(session_resume "$resume_file")"
  elif [[ "$do_resume" -eq 1 ]]; then
    local picked; picked="$(session_pick)"
    if [[ "$picked" == "QUIT" ]]; then info "Cancelled."; return
    elif [[ -n "$picked" ]]; then session_file="$(session_resume "$picked")"
    else session_file="$(session_new "${title:-untitled}")"
    fi
  else
    # Default: new session every time
    session_file="$(session_new "${title:-untitled}")"
  fi

  export SUPER_SESSION_FILE="$session_file"
  session_inject_context "$cli"

  echo ""
  echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
  echo -e "  ${CLI_ICON[$cli]}  ${BOLD}${CLI_LABEL[$cli]}${RESET}"
  echo -e "  📄  $(basename "$session_file")"
  echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
  echo ""

  exec "${CLI_CMD[$cli]}" "${passthrough[@]+"${passthrough[@]}"}"
}

# ─── Resume ───────────────────────────────────────────────────────────────────

cmd_resume() {
  local resume_file="${1:-}"
  local session_file

  if [[ -n "$resume_file" ]]; then
    [[ -f "$resume_file" ]] || resume_file="$(_super_sessions_dir)/$resume_file"
    session_file="$(session_resume "$resume_file")"
  else
    local picked; picked="$(session_pick)"
    [[ "$picked" == "QUIT" || -z "$picked" ]] && { info "Cancelled."; return; }
    session_file="$(session_resume "$picked")"
  fi

  echo ""
  info "Resumed: $(basename "$session_file")"
  _pick_cli_for_session
}

_pick_cli_for_session() {
  echo ""
  echo -e "${BOLD}Launch with which CLI?${RESET}"
  echo ""
  local options=() i=1
  for cli in claude gemini codex kimi; do
    if is_installed "$cli"; then
      options+=("$cli")
      echo -e "  ${BOLD}[$i]${RESET}  ${CLI_ICON[$cli]}  ${CLI_LABEL[$cli]}"
      ((i++))
    fi
  done
  echo ""
  read -rp "  Choice (or q): " choice
  [[ "$choice" == "q" || -z "$choice" ]] && { info "Bye!"; exit 0; }

  if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#options[@]} )); then
    local chosen="${options[$((choice-1))]}"
    local session_file; session_file="$(_super_session_file)"
    session_inject_context "$chosen"
    echo ""
    echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo -e "  ${CLI_ICON[$chosen]}  ${BOLD}${CLI_LABEL[$chosen]}${RESET}"
    echo -e "  📄  $(basename "$session_file")"
    echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
    echo ""
    exec "${CLI_CMD[$chosen]}"
  else
    die "Invalid choice"
  fi
}

# ─── Sessions list ────────────────────────────────────────────────────────────

cmd_sessions() {
  local sessions_dir; sessions_dir="$(_super_sessions_dir)"
  if [[ ! -d "$sessions_dir" ]] || [[ -z "$(ls "$sessions_dir"/*.md 2>/dev/null)" ]]; then
    info "No sessions yet. Run: super install && super launch <cli>"
    return
  fi

  local active; active="$(_super_session_file)"
  echo ""
  echo -e "${BOLD}Sessions in $sessions_dir${RESET}"
  echo ""
  printf "  ${BOLD}%-4s  %-42s  %-20s  %s${RESET}\n" "#" "File" "Started" "Turns"
  echo "  ───────────────────────────────────────────────────────────────────────"

  while IFS=$'\t' read -r idx fname started turns marker; do
    local col="$RESET"
    [[ -n "${marker:-}" ]] && col="$GREEN"
    printf "  ${col}%-4s  %-42s  %-20s  %s%s${RESET}\n" \
      "$idx" "$fname" "$started" "$turns" "${marker:-}"
  done < <(session_list)
  echo ""
}

# ─── Log viewer ───────────────────────────────────────────────────────────────

cmd_log() {
  local arg="${1:-}"
  local target_file

  if [[ -n "$arg" && "$arg" =~ \.md$ ]]; then
    local candidate="$(_super_sessions_dir)/$arg"
    [[ -f "$candidate" ]] && target_file="$candidate" || target_file="$arg"
  elif [[ -n "$arg" && "$arg" =~ ^[0-9]+$ ]]; then
    local af; af="$(_super_session_file)"
    [[ -f "$af" ]] || { warn "No active session."; return; }
    echo ""; info "Last $arg turns — $(basename "$af")"; echo ""
    grep -A 20 '^## ' "$af" | tail -n "$((arg * 20))"
    return
  else
    target_file="$(_super_session_file)"
  fi

  if [[ -z "$target_file" || ! -f "$target_file" ]]; then
    warn "No session to show. Start one with: super launch <cli>"
    return
  fi

  if command -v bat &>/dev/null; then bat --language=markdown "$target_file"
  elif command -v less &>/dev/null; then less "$target_file"
  else cat "$target_file"; fi
}

# ─── Switch ───────────────────────────────────────────────────────────────────

cmd_switch() {
  local to_cli="${1:-}"
  [[ -z "$to_cli" ]] && die "Usage: super switch <cli>"
  to_cli="${to_cli,,}"
  [[ -z "${CLI_CMD[$to_cli]+_}" ]] && die "Unknown CLI: $to_cli"
  is_installed "$to_cli" || die "${CLI_LABEL[$to_cli]} is not installed"

  local sf; sf="$(_super_session_file)"
  [[ -z "$sf" || ! -f "$sf" ]] && { warn "No active session — creating one"; sf="$(session_new "untitled")"; }

  info "Switching to ${CLI_LABEL[$to_cli]}  ($(basename "$sf"))"
  session_inject_context "$to_cli"
  echo ""
  echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
  echo -e "  ${CLI_ICON[$to_cli]}  ${BOLD}${CLI_LABEL[$to_cli]}${RESET}"
  echo -e "  📄  $(basename "$sf")"
  echo -e "${BOLD}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
  echo ""
  exec "${CLI_CMD[$to_cli]}"
}

cmd_clean() { info "Removing context injections..."; session_clear_injections; ok "Done"; }

cmd_uninstall() {
  local root; root="$(_super_find_root)"
  info "Removing super hooks..."

  _strip_json_hooks() {
    local f="$1" idf="$2"
    [[ -f "$f" ]] || return
    python3 - "$f" "$idf" <<'PYEOF'
import sys, json
path, idf = sys.argv[1], sys.argv[2]
with open(path) as fh: data = json.load(fh)
if "hooks" in data:
    for ev in list(data["hooks"].keys()):
        data["hooks"][ev] = [
            g for g in data["hooks"][ev]
            if not any("super" in h.get(idf,"") for h in g.get("hooks",[]))
        ]
        if not data["hooks"][ev]: del data["hooks"][ev]
with open(path,"w") as fh: json.dump(data,fh,indent=2); fh.write("\n")
PYEOF
    ok "Cleaned $f"
  }

  _strip_json_hooks "$root/.claude/settings.json" "command"
  _strip_json_hooks "$root/.gemini/settings.json" "name"
  _strip_json_hooks "$root/.codex/hooks.json"     "command"

  local kf="$root/.kimi/config.toml"
  if [[ -f "$kf" ]]; then
    python3 - "$kf" <<'PYEOF'
import sys, re
with open(sys.argv[1]) as f: c = f.read()
c = re.sub(r'\n# super hooks\n.*?(?=\n\[|\Z)', '', c, flags=re.DOTALL)
with open(sys.argv[1],"w") as f: f.write(c)
PYEOF
    ok "Cleaned $kf"
  fi

  session_clear_injections
  echo ""; info "Hooks removed. Sessions preserved at $(_super_sessions_dir)"
}

# ─── Menu ─────────────────────────────────────────────────────────────────────

cmd_menu() {
  print_status
  local sessions_dir; sessions_dir="$(_super_sessions_dir)"
  local has_sessions=0
  [[ -d "$sessions_dir" ]] && [[ -n "$(ls "$sessions_dir"/*.md 2>/dev/null)" ]] \
    && has_sessions=1

  echo -e "${BOLD}What would you like to do?${RESET}"
  echo ""
  echo -e "  ${BOLD}[1]${RESET}  🆕  Start a new session"
  if [[ "$has_sessions" -eq 1 ]]; then
    echo -e "  ${BOLD}[2]${RESET}  ↩️   Resume a previous session"
  fi
  echo ""
  read -rp "  Choice (or q): " choice
  [[ "$choice" == "q" || -z "$choice" ]] && { info "Bye!"; exit 0; }

  case "$choice" in
    1) _pick_cli_and_launch ;;
    2) [[ "$has_sessions" -eq 1 ]] && cmd_resume || die "Invalid choice" ;;
    *) die "Invalid choice: $choice" ;;
  esac
}

# ─── Pick CLI and launch ──────────────────────────────────────────────────────

_pick_cli_and_launch() {
  echo ""
  echo -e "${BOLD}Which CLI would you like to use?${RESET}"
  echo ""
  local options=() i=1
  for cli in claude gemini codex kimi; do
    if is_installed "$cli"; then
      options+=("$cli")
      echo -e "  ${BOLD}[$i]${RESET}  ${CLI_ICON[$cli]}  ${CLI_LABEL[$cli]}"
      ((i++))
    fi
  done
  echo ""
  read -rp "  Choice (or q): " choice
  [[ "$choice" == "q" || -z "$choice" ]] && { info "Bye!"; exit 0; }

  if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#options[@]} )); then
    local chosen="${options[$((choice-1))]}"
    cmd_launch "$chosen"
  else
    die "Invalid choice: $choice"
  fi
}

# ─── Help ─────────────────────────────────────────────────────────────────────

cmd_help() {
  print_banner
  cat << 'HELPEOF'
USAGE
  super [command] [args]

COMMANDS
  install [all|claude|gemini|codex|kimi]
      Install hooks into CLI config files. Defaults to all four.

  launch <cli> [--title <name>] [--resume [file]] [cli-args...]
      Start a NEW session and launch a CLI.
        --title <name>    Name the session (e.g. --title auth-refactor)
        --resume          Show picker to resume or start new
        --resume <file>   Resume a specific session file

  resume [file]
      Pick a past session and choose which CLI to launch it in.
      File can be a full path or just the filename.

  sessions
      List all sessions for this project, with turn counts.

  switch <cli>
      Re-inject the active session into a different CLI and launch it.
      Continues the current session — does NOT create a new one.

  log [N | file.md]
      View the active session. Pass N for last N turns.
      Pass a filename to view a specific session.

  clean
      Remove injection blocks from CLAUDE.md / GEMINI.md / AGENTS.md.

  uninstall
      Remove super hooks from all CLI config files.

  status
      Show CLI availability and session info.

EXAMPLES
  super install
  super claude                                  # new untitled session
  super launch gemini --title "auth refactor"   # named session
  super launch claude --resume                  # pick session or new
  super resume                                  # pick session, pick CLI
  super resume 2026-04-11_143201_auth-refactor.md
  super switch gemini                           # continue in Gemini
  super sessions
  super log
  super log 10

SESSION FILES
  .super/sessions/<YYYY-MM-DD_HHMMSS>_<title>.md
  Active session tracked in .super/active

HOOKS COVERAGE
  🟠 Claude Code  — SessionStart, UserPromptSubmit, PostToolUse, Stop
  🔵 Gemini CLI   — SessionStart, UserPromptSubmit, AfterTool, AfterAgent
  🟢 Codex CLI    — SessionStart, UserPromptSubmit, PostToolUse (Bash), Stop
  🟡 Kimi Code    — SessionStart, UserPromptSubmit, PostToolUse, Stop
HELPEOF
}

# ─── Dispatch ─────────────────────────────────────────────────────────────────

main() {
  local cmd="${1:-menu}"
  shift || true
  case "$cmd" in
    install|i)         cmd_install "$@" ;;
    launch|l|run)      cmd_launch "$@" ;;
    resume|r)          cmd_resume "$@" ;;
    sessions|ls|list)  cmd_sessions ;;
    switch|sw)         cmd_switch "$@" ;;
    log|show)          cmd_log "$@" ;;
    clean)             cmd_clean ;;
    uninstall)         cmd_uninstall ;;
    status|s)          print_banner; print_status ;;
    --version|-v)      echo "super v$SUPER_VERSION"; exit 0 ;;
    help|--help|-h)    cmd_help ;;
    menu)              print_banner; cmd_menu ;;
    claude|gemini|codex|kimi) cmd_launch "$cmd" "$@" ;;
    *) die "Unknown command: $cmd. Run: super help" ;;
  esac
}

main "$@"
