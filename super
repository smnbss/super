# SWITCH COMMAND
# ═══════════════════════════════════════════════════════════════════════════════

cmd_switch() {
  local to_cli="${1:-}"
  
  [[ -z "$to_cli" ]] && die "Usage: super switch <cli>"
  to_cli="${to_cli,,}"
  [[ -z "${CLI_CMD[$to_cli]+_}" ]] && die "Unknown CLI: $to_cli"
