# ═══════════════════════════════════════════════════════════════════════════════
# UNINSTALL COMMAND
# ═══════════════════════════════════════════════════════════════════════════════

cmd_uninstall() {
  local root; root="$(_super_find_root)"
  ui_brand "Removing super hooks..."

  _strip_json_hooks() {
    local f="$1" idf="$2"
    [[ -f "$f" ]] || return
    python3 - "$f" "$idf" <<'PYEOF'
import sys, json
path, idf = sys.argv[1], sys.argv[2]
with open(path) as fh: data = json.load(fh)
if "hooks" in data:
    for ev in list(data["hooks"].keys()):
        data["hooks"][ev] = [
            g for g in data["hooks"][ev]
            if not any("super" in h.get(idf,"") for h in g.get("hooks",[]))
        ]
        if not data["hooks"][ev]: del data["hooks"][ev]
with open(path,"w") as fh: json.dump(data,fh,indent=2); fh.write("\n")
PYEOF
    ui_success "Cleaned $f"
  }

  _strip_json_hooks "$root/.claude/settings.json" "command"
  _strip_json_hooks "$root/.gemini/settings.json" "name"
  _strip_json_hooks "$root/.codex/hooks.json"     "command"

  local kf="$root/.kimi/config.toml"
  if [[ -f "$kf" ]]; then
    python3 - "$kf" <<'PYEOF'
import sys, re
with open(sys.argv[1]) as f: c = f.read()
c = re.sub(r'\n# super hooks\n.*?(?=\n\[|\Z)', '', c, flags=re.DOTALL)
with open(sys.argv[1],"w") as f: f.write(c)
PYEOF
    ui_success "Cleaned $kf"
  fi

  session_clear_injections
  ui_spacer
  ui_info "Hooks removed. Sessions preserved at $(_super_sessions_dir)"
}

# ═══════════════════════════════════════════════════════════════════════════════
# MENU COMMAND
# ═══════════════════════════════════════════════════════════════════════════════

cmd_menu() {
  local sessions_dir; sessions_dir="$(_super_sessions_dir)"
  local has_sessions=0
  [[ -d "$sessions_dir" ]] && [[ -n "$(ls "$sessions_dir"/*.md 2>/dev/null)" ]] && has_sessions=1
  
  local active; active="$(_super_session_file)"
  
  # If there's an active session, offer quick continuation
  if [[ -n "$active" && -f "$active" && "$has_sessions" -eq 1 ]]; then
    local turns; turns="$(grep -c '^## ' "$active" 2>/dev/null || echo 0)"
    local name; name="$(basename "$active" .md)"
    
    ui_banner
    ui_print "  $(_c $UI_SUCCESS)${UI_ICON_ACTIVE}${UI_RESET} $(_c $UI_BOLD)Active:${UI_RESET} $name ($turns turns)"
    ui_spacer
    
    local options=(
      "↩  Continue active session"
      "🆕 Start new session"
      "↩️  Resume different session"
      "📊 View status"
      "🩺 Run doctor"
      "🚪 Quit"
    )
    
    local choice
    choice=$(ui_select_single "What would you like to do?" 0 "${options[@]}")
    
    [[ -z "$choice" ]] && { ui_info "Bye!"; exit 0; }
    
    case "$choice" in
      0)  # Continue active
        local last_cli; last_cli="$(detect_last_cli)"
        if [[ -n "$last_cli" ]]; then
          cmd_launch "$last_cli" --resume
        else
          cmd_resume
        fi
        ;;
      1) _pick_cli_and_launch ;;  # New session
      2) cmd_resume ;;             # Resume different
      3) print_banner; print_status ;;  # Status
      4) cmd_doctor ;;             # Doctor
      5) ui_info "Bye!"; exit 0 ;; # Quit
    esac
    return
  fi
  
  # No active session — show standard menu
  ui_banner
  
  local options=("🆕 Start a new session")
  [[ "$has_sessions" -eq 1 ]] && options+=("↩️  Resume a previous session")
  options+=("🩺 Run health check (doctor)")
  options+=("🚪 Quit")
  
  local choice
  choice=$(ui_select_single "What would you like to do?" 0 "${options[@]}")
  
  [[ -z "$choice" ]] && { ui_info "Bye!"; exit 0; }
  
  # Map selection to action — idx tracks position in dynamic options list
  local idx=0

  # "new" is always first
  [[ "$choice" -eq $idx ]] && { _pick_cli_and_launch; return; }
  idx=$((idx + 1))

  # "resume" only if sessions exist
  if [[ "$has_sessions" -eq 1 ]]; then
    [[ "$choice" -eq $idx ]] && { cmd_resume; return; }
    idx=$((idx + 1))
  fi

  # "doctor"
  [[ "$choice" -eq $idx ]] && { cmd_doctor; return; }
  idx=$((idx + 1))

  # "quit"
  ui_info "Bye!"; exit 0
}

# Detect last CLI used in active session
detect_last_cli() {
  local session_file; session_file="$(_super_session_file)"
  [[ -f "$session_file" ]] || return
  
  local last_turn; last_turn="$(grep '^## ' "$session_file" 2>/dev/null | tail -1 || true)"
  [[ "$last_turn" == *"🟠"* ]] && echo "claude" && return
  [[ "$last_turn" == *"🔵"* ]] && echo "gemini" && return
  [[ "$last_turn" == *"🟢"* ]] && echo "codex" && return
  [[ "$last_turn" == *"🟡"* ]] && echo "kimi" && return
}

# ═══════════════════════════════════════════════════════════════════════════════
# CLI PICKER
# ═══════════════════════════════════════════════════════════════════════════════

_pick_cli_and_launch() {
  # Build list of installed CLIs
  local options=()
  local cli_keys=()
  for cli in claude gemini codex kimi; do
    if is_installed "$cli"; then
      options+=("${CLI_ICON[$cli]} ${CLI_LABEL[$cli]}")
      cli_keys+=("$cli")
    fi
  done

  [[ ${#options[@]} -eq 0 ]] && die "No CLIs installed. Install one first."
  [[ ${#options[@]} -eq 1 ]] && { cmd_launch "${cli_keys[0]}"; return; }

  local choice
  choice=$(ui_select_single "Which CLI would you like to use?" 0 "${options[@]}")

  [[ -z "$choice" ]] && { ui_info "Cancelled."; return 1; }

  cmd_launch "${cli_keys[$choice]}"
}

