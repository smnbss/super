cmd_config_interactive() {
  print_banner
  ui_section "Interactive Configuration"

  # Ensure config exists
  local cfg; cfg="$(_super_find_config)"
  [[ -f "$cfg" ]] || { _super_config_init; cfg="$(_super_find_config)"; }

  while true; do
    local options=(
      "🧩 Skills — manage installed skills"
      "🔌 Plugins — manage plugin repos"
      "🔗 MCPs — manage MCP servers"
      "📁 Sessions — cleanup, transcripts"
      "🔒 Security — yolo mode, path restrictions"
      "👁  View current config"
      "✏️  Edit config in editor"
      "🚪 Done"
    )

    local choice
    choice=$(ui_select_single "Configuration" 0 "${options[@]}")

    [[ -z "$choice" ]] && { ui_info "Done!"; return; }

