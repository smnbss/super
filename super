#!/usr/bin/env bash
# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  super v1.2 — cross-CLI session bridge                                       ║
# ║  Claude Code · Gemini CLI · Codex CLI · Kimi Code CLI                       ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# Handle --version before anything else (works even on bash 3)
if [[ "${1:-}" == "--version" || "${1:-}" == "-v" ]]; then
  cat "$(dirname "${BASH_SOURCE[0]}")/VERSION" 2>/dev/null || echo "unknown"
  exit 0
fi

# Bash version check (before associative arrays)
if [[ "${BASH_VERSINFO[0]}" -lt 4 ]]; then
  echo "error: super requires bash 4+. You have $BASH_VERSION" >&2
  echo "Install with: brew install bash" >&2
  exit 1
fi

set -euo pipefail

SUPER_HOME="${SUPER_HOME:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"
export SUPER_HOME
SUPER_VERSION="$(cat "$SUPER_HOME/VERSION" 2>/dev/null || echo "unknown")"
GUM_AVAILABLE="$(command -v gum >/dev/null 2>&1 && echo "true" || echo "false")"

# Source libraries
source "$SUPER_HOME/lib/session.sh"
source "$SUPER_HOME/lib/config.sh"
source "$SUPER_HOME/lib/ui.sh"
source "$SUPER_HOME/lib/fzf.sh"
source "$SUPER_HOME/lib/interactive.sh"
source "$SUPER_HOME/lib/catalog.sh"

# Legacy color compatibility (deprecated, use ui_* functions)
RED="\033[0;31m"; GREEN="\033[0;32m"; YELLOW="\033[1;33m"
CYAN="\033[0;36m"; BOLD="\033[1m"; DIM="\033[2m"; RESET="\033[0m"

declare -A CLI_CMD=(   [claude]="claude" [gemini]="gemini" [codex]="codex" [kimi]="kimi" )
declare -A CLI_ICON=(  [claude]="🟠"     [gemini]="🔵"     [codex]="🟢"    [kimi]="🟡"  )
declare -A CLI_LABEL=( [claude]="Claude Code" [gemini]="Gemini CLI" [codex]="Codex CLI" [kimi]="Kimi Code CLI" )
declare -A CLI_CTX=(   [claude]="CLAUDE.md"   [gemini]="GEMINI.md"  [codex]="AGENTS.md" [kimi]="AGENTS.md"    )

# Legacy helpers (deprecated, use ui_*)
die()  { ui_error "$*"; exit 1; }
info() { ui_brand "$*"; }
ok()   { ui_success "$*"; }
warn() { ui_warn "$*"; }

is_installed() { command -v "${CLI_CMD[$1]}" &>/dev/null; }

# ═══════════════════════════════════════════════════════════════════════════════
# BANNER & STATUS
# ═══════════════════════════════════════════════════════════════════════════════

print_banner() {
  ui_spacer
  ui_print "  ╭──────────────────────────────────────────╮"
  ui_print "  │  🔀  super v${SUPER_VERSION}                   │"
  ui_print "  │  Cross-CLI session bridge                │"
  ui_print "  ╰──────────────────────────────────────────╯"
  ui_spacer
}

print_status() {
  ui_section "CLIs"
  for cli in claude gemini codex kimi; do
    local icon="${CLI_ICON[$cli]}" label="${CLI_LABEL[$cli]}"
    if is_installed "$cli"; then
      ui_print "  $icon  $(_c $UI_SUCCESS)${label}${UI_RESET}  $(_c $UI_MUTED)$(command -v "${CLI_CMD[$cli]}")${UI_RESET}"
    else
      ui_print "  $icon  $(_c $UI_ERROR)${label}${UI_RESET}  $(_c $UI_MUTED)(not installed)${UI_RESET}"
    fi
  done
  
  ui_section "Sessions"
  local sessions_dir; sessions_dir="$(_super_sessions_dir)"
  local active; active="$(_super_session_file)"
  
  if [[ -d "$sessions_dir" ]]; then
    local total today week
    total="$(ls "$sessions_dir"/*.md 2>/dev/null | wc -l | tr -d ' ' || echo 0)"
    today="$(find "$sessions_dir" -name '*.md' -mtime -1 2>/dev/null | wc -l | tr -d ' ' || echo 0)"
    week="$(find "$sessions_dir" -name '*.md' -mtime -7 2>/dev/null | wc -l | tr -d ' ' || echo 0)"
    
    ui_print "  📁 $total total  |  $today today  |  $week this week"
    
    if [[ -n "$active" && -f "$active" ]]; then
      local turns size
      turns="$(grep -c '^## ' "$active" 2>/dev/null || echo 0)"
      size="$(stat -f %z "$active" 2>/dev/null || stat -c %s "$active" 2>/dev/null || echo 0)"
      
      ui_spacer
      ui_print "  $(_c $UI_SUCCESS)${UI_ICON_ACTIVE}${UI_RESET} ${UI_BOLD}ACTIVE:${UI_RESET} $(basename "$active")"
      local last_mod; last_mod="$(stat -f %Sm -t '%H:%M' "$active" 2>/dev/null || stat -c %y "$active" 2>/dev/null | cut -d' ' -f2 | cut -d':' -f1,2 || echo '??:??')"
      ui_print "     $turns turns  |  $(ui_human_size $size)  |  Last: $last_mod"
      
      # Recent activity preview (last 3 turns)
      ui_spacer
      ui_print "  $(_c $UI_MUTED)Recent activity:${UI_RESET}"
      grep -E '^## .*User|^### .*Assistant' "$active" 2>/dev/null | tail -6 | while read -r line; do
        if [[ "$line" == *"User"* ]]; then
          local content
          content="$(echo "$line" | sed 's/.*User//' | head -c 50)"
          [[ ${#content} -eq 50 ]] && content="${content}..."
          ui_print "    $(_c $UI_MUTED)•${UI_RESET} 👤 $content"
        fi
      done
      
      ui_spacer
      ui_muted "  Quick actions:"
      ui_muted "    super resume    # Continue this session"
      ui_muted "    super switch    # Continue in different CLI"
      ui_muted "    super log 5     # Last 5 turns"
    fi
  else
    ui_warn "No sessions yet."
    ui_muted "  Run: super install"
  fi
  
  ui_spacer
  fzf_status
  gum_status
  ui_spacer
}

# ═══════════════════════════════════════════════════════════════════════════════
# DOCTOR COMMAND
# ═══════════════════════════════════════════════════════════════════════════════

cmd_doctor() {
  print_banner
  ui_section "Health Check"
  
  local issues=0
  local root; root="$(_super_find_root)"
  
  # Check CLI hooks
  ui_print "$(_c $UI_MUTED)Checking CLI hooks...${UI_RESET}"
  for cli in claude gemini codex kimi; do
    local config_file=""
    local hook_type=""
    case "$cli" in
      claude) config_file="$HOME/.claude/settings.json"; hook_type="command" ;;
      gemini) config_file="$HOME/.gemini/settings.json"; hook_type="name" ;;
      codex)  config_file="$HOME/.codex/hooks.json";     hook_type="command" ;;
      kimi)   config_file="$HOME/.kimi/config.toml";     ;;
    esac
    
    if [[ -f "$config_file" ]]; then
      if grep -q "super" "$config_file" 2>/dev/null; then
        ui_success "${CLI_ICON[$cli]} ${CLI_LABEL[$cli]} hooks installed"
      else
        ui_warn "${CLI_ICON[$cli]} ${CLI_LABEL[$cli]} hooks not found"
        ui_muted "      Run: super install $cli"
        issues=$((issues + 1))
      fi
    else
      ui_muted "  ${CLI_ICON[$cli]} ${CLI_LABEL[$cli]} — no config file"
    fi
  done
  
  # Check context files
  ui_spacer
  ui_print "$(_c $UI_MUTED)Checking context files...${UI_RESET}"
  
  if [[ -L "$root/CLAUDE.md" && -L "$root/GEMINI.md" && -f "$root/AGENTS.md" ]]; then
    ui_success "Context files correctly symlinked (AGENTS.md master)"
  elif [[ -f "$root/CLAUDE.md" && ! -L "$root/CLAUDE.md" ]]; then
    ui_warn "CLAUDE.md is a regular file (not symlinked)"
    ui_muted "      Run: super install to fix"
    issues=$((issues + 1))
  else
    ui_warn "Context files not set up"
    ui_muted "      Run: super install"
    issues=$((issues + 1))
  fi
  
  # Check session health
  ui_spacer
  ui_print "$(_c $UI_MUTED)Checking sessions...${UI_RESET}"
  
  local sessions_dir; sessions_dir="$(_super_sessions_dir)"
  if [[ -d "$sessions_dir" ]]; then
    local count
    count="$(ls "$sessions_dir"/*.md 2>/dev/null | wc -l | tr -d ' ' || echo 0)"
    ui_success "$count session(s) found"

    # Check for old sessions
    local old
    old="$(find "$sessions_dir" -name '*.md' -mtime +30 2>/dev/null | wc -l | tr -d ' ' || echo 0)"
    if ((old > 0)); then
      ui_warn "$old session(s) older than 30 days"
      ui_muted "      Run: super cleanup 30"
    fi
    
    # Check for large sessions
    local large
    large="$(find "$sessions_dir" -name '*.md' -size +1M 2>/dev/null || true)"
    if [[ -n "$large" ]]; then
      ui_warn "Large sessions detected (slow context injection):"
      echo "$large" | while read -r f; do
        ui_muted "      $(basename "$f"): $(du -h "$f" 2>/dev/null | cut -f1)"
      done
    fi
  else
    ui_muted "  No sessions directory"
  fi
  
  # Summary
  ui_spacer
  ui_rule
  if [[ $issues -eq 0 ]]; then
    ui_success "All checks passed — super is healthy!"
  else
    ui_warn "Found $issues issue(s) to address"
  fi
}

# ═══════════════════════════════════════════════════════════════════════════════
# HOOKS INSTALLATION
# ═══════════════════════════════════════════════════════════════════════════════

_merge_json_hooks() {
  local file="$1" new_json="$2" id_field="$3"
  python3 - "$file" "$new_json" "$id_field" <<'PYEOF'
import sys, json
path, new_json, idf = sys.argv[1], sys.argv[2], sys.argv[3]
with open(path) as f: existing = json.load(f)
new_data = json.loads(new_json)
new_hooks = new_data.get("hooks", {})
new_env = new_data.get("env", {})

# Merge env section
if new_env:
    if "env" not in existing: existing["env"] = {}
    for key, value in new_env.items():
        existing["env"][key] = value

# Merge hooks section
if "hooks" not in existing: existing["hooks"] = {}

for event, new_defs in new_hooks.items():
    if event not in existing["hooks"]:
        existing["hooks"][event] = new_defs
    else:
        existing_hooks = existing["hooks"][event]
        for new_def in new_defs:
            new_commands = [h.get(idf, "") for h in new_def.get("hooks", [])]
            already_present = False
            for existing_def in existing_hooks:
                existing_commands = [h.get(idf, "") for h in existing_def.get("hooks", [])]
                if any(nc in existing_commands for nc in new_commands if nc):
                    already_present = True
                    break
            if not already_present:
                existing_hooks.append(new_def)

with open(path,"w") as f: json.dump(existing,f,indent=2); f.write("\n")
PYEOF
}

install_hooks_claude() {
  local dir="$HOME/.claude"; mkdir -p "$dir"
  local sf="$dir/settings.json"
  local template="$SUPER_HOME/hooks/claude/settings.json.template"
  
  # Expand $SUPER_HOME in env section, keep {{SUPER_HOME}} as variable in commands
  local expanded; expanded="$(SUPER_HOME="$SUPER_HOME" envsubst < "$template" | sed 's/{{SUPER_HOME}}/$SUPER_HOME/g')"
  
  if [[ -f "$sf" ]]; then _merge_json_hooks "$sf" "$expanded" "command"; ui_success "Updated $sf"
  else echo "$expanded" > "$sf"; ui_success "Created $sf"; fi
  chmod +x "$SUPER_HOME"/hooks/claude/*.sh
}

install_hooks_gemini() {
  local dir="$HOME/.gemini"; mkdir -p "$dir"
  local gf="$dir/settings.json"
  local template="$SUPER_HOME/hooks/gemini/settings.json.template"
  
  # Expand $SUPER_HOME in env section, keep {{SUPER_HOME}} as variable in commands
  local expanded; expanded="$(SUPER_HOME="$SUPER_HOME" envsubst < "$template" | sed 's/{{SUPER_HOME}}/$SUPER_HOME/g')"
  
  if [[ -f "$gf" ]]; then _merge_json_hooks "$gf" "$expanded" "name"; ui_success "Updated $gf"
  else echo "$expanded" > "$gf"; ui_success "Created $gf"; fi
  chmod +x "$SUPER_HOME"/hooks/gemini/*.sh
}

install_hooks_codex() {
  local dir="$HOME/.codex"; mkdir -p "$dir"
  local hf="$dir/hooks.json"
  local template="$SUPER_HOME/hooks/codex/hooks.json.template"
  
  # Expand $SUPER_HOME in env section, keep {{SUPER_HOME}} as variable in commands
  local expanded; expanded="$(SUPER_HOME="$SUPER_HOME" envsubst < "$template" | sed 's/{{SUPER_HOME}}/$SUPER_HOME/g')"
  
  if [[ -f "$hf" ]]; then _merge_json_hooks "$hf" "$expanded" "command"; ui_success "Updated $hf"
  else echo "$expanded" > "$hf"; ui_success "Created $hf"; fi
  chmod +x "$SUPER_HOME"/hooks/codex/*.sh
}

install_hooks_kimi() {
  local cfg="$HOME/.kimi/config.toml"; mkdir -p "$(dirname "$cfg")"
  local template="$SUPER_HOME/hooks/kimi/config.toml.template"
  
  # Expand $SUPER_HOME in comments, keep {{SUPER_HOME}} as variable in commands
  local expanded; expanded="$(SUPER_HOME="$SUPER_HOME" envsubst < "$template" | sed 's/{{SUPER_HOME}}/$SUPER_HOME/g')"
  
  if [[ -f "$cfg" ]]; then
    local already_present=0
    if grep -q "super hooks for Kimi" "$cfg" 2>/dev/null; then
      already_present=1
    fi
    
    if [[ "$already_present" -eq 1 ]]; then
      ui_warn "super hooks already in $cfg — skipping"
    else
      printf '\n# super hooks\n%s\n' "$expanded" >> "$cfg"
      ui_success "Updated $cfg"
    fi
  else
    printf '# Kimi config\n# super hooks\n%s\n' "$expanded" > "$cfg"
    ui_success "Created $cfg"
  fi
  chmod +x "$SUPER_HOME"/hooks/kimi/*.sh
}

_setup_context_files() {
  local root; root="$(_super_find_root)"
  local claude_md="$root/CLAUDE.md"
  local gemini_md="$root/GEMINI.md"
  local agents_md="$root/AGENTS.md"

  local existing=""
  [[ -f "$claude_md" && ! -L "$claude_md" ]] && existing="$claude_md"
  [[ -f "$gemini_md" && ! -L "$gemini_md" ]] && existing="$gemini_md"
  [[ -f "$agents_md" && ! -L "$agents_md" ]] && existing="$agents_md"

  if [[ -n "$existing" ]]; then
    local target="$existing"
    local target_name; target_name="$(basename "$target")"
    ui_info "Found existing $target_name — symlinking other context files"

    if [[ "$target" != "$claude_md" ]]; then
      [[ -e "$claude_md" || -L "$claude_md" ]] && rm "$claude_md"
      ln -s "$target_name" "$claude_md" && ui_success "CLAUDE.md → $target_name"
    fi
    if [[ "$target" != "$gemini_md" ]]; then
      [[ -e "$gemini_md" || -L "$gemini_md" ]] && rm "$gemini_md"
      ln -s "$target_name" "$gemini_md" && ui_success "GEMINI.md → $target_name"
    fi
    if [[ "$target" != "$agents_md" ]]; then
      [[ -e "$agents_md" || -L "$agents_md" ]] && rm "$agents_md"
      ln -s "$target_name" "$agents_md" && ui_success "AGENTS.md → $target_name"
    fi
  else
    ui_info "Creating context files (AGENTS.md as master)"
    echo "# Agents Configuration" > "$agents_md"
    ui_success "Created AGENTS.md"

    ln -s "AGENTS.md" "$claude_md" && ui_success "CLAUDE.md → AGENTS.md"
    ln -s "AGENTS.md" "$gemini_md" && ui_success "GEMINI.md → AGENTS.md"
  fi
}

cmd_install() {
  local target=""
  local use_interactive=false

  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --interactive|-i) use_interactive=true; shift ;;
      -*) die "Unknown option: $1" ;;
      *)  target="$1"; shift ;;
    esac
  done

  # Check if this is a first-time install (no config in project)
  local is_first_time=false
  local cfg; cfg="$(_super_find_config)"
  [[ -z "$cfg" || ! -f "$cfg" ]] && is_first_time=true

  # Use interactive mode if: --interactive, no target, or first time
  if [[ "$use_interactive" == "true" ]] || [[ -z "$target" ]]; then
    # Step 1: Pick CLIs to install hooks for
    cmd_install_interactive

    # Step 2: Copy config template if first time
    if [[ "$is_first_time" == "true" ]]; then
      ui_spacer
      _install_config_template
    fi

    # Step 3: Offer to configure skills/plugins/MCPs
    local has_config; has_config="$(_super_find_config)"
    if [[ -f "$has_config" ]]; then
      ui_spacer
      if ui_confirm "Configure skills, plugins & MCPs?" "yes"; then
        _config_interactive_skills
        _config_interactive_plugins
        _config_interactive_mcps
        ui_spacer
        if ui_confirm "Install enabled skills/plugins/MCPs now?" "yes"; then
          catalog_install_enabled
        fi
      fi
    fi

    _install_finish
    return
  fi

  # Non-interactive mode with explicit target
  ui_brand "Installing hooks (target: $target)"
  ui_spacer

  case "$target" in
    all)    install_hooks_claude; install_hooks_gemini
            install_hooks_codex;  install_hooks_kimi ;;
    claude) install_hooks_claude ;;
    gemini) install_hooks_gemini ;;
    codex)  install_hooks_codex  ;;
    kimi)   install_hooks_kimi   ;;
    *) die "Unknown CLI: $target. Use: all|claude|gemini|codex|kimi" ;;
  esac

  _install_finish
}

_install_config_template() {
  local dest; dest="$(pwd)/super.config.yaml"
  local template="$SUPER_HOME/super.config.yaml"

  if [[ -f "$dest" ]]; then
    ui_muted "Config already exists: $dest"
    return
  fi

  if [[ -f "$template" ]]; then
    cp "$template" "$dest"
    ui_success "Created super.config.yaml from template"
  else
    _super_config_init
    ui_success "Created super.config.yaml with defaults"
  fi
}

_install_finish() {
  mkdir -p "$(_super_sessions_dir)"
  _setup_context_files

  ui_spacer
  ui_success "Sessions folder ready: $(_super_sessions_dir)"
  ui_muted "Run $(ui_bold "super launch <cli>") to start your first session"

  # First-time help
  if [[ ! -d "$(_super_sessions_dir)" ]] || [[ -z "$(ls -A "$(_super_sessions_dir)"/*.md 2>/dev/null)" ]]; then
    ui_spacer
    ui_box \
      "What super does:" \
      "" \
      "1. Start: super claude" \
      "2. Work — super logs silently" \
      "3. Switch: super switch gemini" \
      "4. Continue seamlessly" \
      "" \
      "Your conversation follows you."
  fi
}

# ═══════════════════════════════════════════════════════════════════════════════
# LAUNCH COMMAND
# ═══════════════════════════════════════════════════════════════════════════════

cmd_launch() {
  local cli="${1:-}"
  shift || true

  local do_resume=0 resume_file="" title=""
  local passthrough=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --resume|-r)
        do_resume=1; shift
        if [[ $# -gt 0 && "${1:-}" != --* && "${1:-}" != -* ]]; then
          resume_file="$1"; shift
        fi ;;
      --title|-t) shift; title="${1:-}"; shift ;;
      *) passthrough+=("$1"); shift ;;
    esac
  done

  [[ -z "$cli" ]] && { cmd_menu; return; }
  cli="${cli,,}"
  [[ -z "${CLI_CMD[$cli]+_}" ]] && die "Unknown CLI: $cli"
  is_installed "$cli" || die "${CLI_LABEL[$cli]} is not installed"

  # Cleanup old sessions if configured
  if _super_session_cleanup; then
    local max_age="$(_super_session_max_age)"
    [[ -n "$max_age" ]] && session_cleanup_old "$max_age" &>/dev/null || true
  fi

  # Check session size before launch
  local session_file
  
  if [[ -n "$resume_file" ]]; then
    [[ -f "$resume_file" ]] || resume_file="$(_super_sessions_dir)/$resume_file"
    session_file="$(session_resume "$resume_file")"
  elif [[ "$do_resume" -eq 1 ]]; then
    local picked; picked="$(fzf_pick_session)"
    if [[ "$picked" == "QUIT" ]]; then ui_info "Cancelled."; return
    elif [[ "$picked" == "NEW" || -z "$picked" ]]; then session_file="$(session_new "${title:-untitled}")"
    else session_file="$(session_resume "$picked")"
    fi
  else
    session_file="$(session_new "${title:-untitled}")"
  fi
  
  # Warn about large sessions
  local size; size="$(stat -f %z "$session_file" 2>/dev/null || stat -c %s "$session_file" 2>/dev/null || echo 0)"
  if (( size > 1048576 )); then
    ui_warn "Large session ($(ui_human_size $size)) — context injection may be slow"
  fi

  export SUPER_SESSION_FILE="$session_file"
  session_inject_context "$cli"

  # Run catchup if resuming
  if [[ "$do_resume" -eq 1 && -n "$session_file" ]]; then
    SUPER_SESSION_FILE="$session_file" cmd_catchup
  fi

  ui_spacer
  ui_rule 60
  ui_print "  ${CLI_ICON[$cli]}  $(ui_bold "${CLI_LABEL[$cli]}")"
  ui_print "  📄  $(basename "$session_file")"
  ui_rule 60
  ui_spacer

  exec "${CLI_CMD[$cli]}" "${passthrough[@]:-}"
}

# ═══════════════════════════════════════════════════════════════════════════════
# RESUME COMMAND
# ═══════════════════════════════════════════════════════════════════════════════

cmd_resume() {
  local input="${1:-}"
  
  if [[ -n "$input" ]]; then
    # Session file provided - pick CLI to resume in
    local session_file
    [[ -f "$input" ]] || input="$(_super_sessions_dir)/$input"
    [[ -f "$input" ]] || die "Session not found: $1"
    session_file="$input"
    
    ui_msg_resuming "$(basename "$session_file")"
    echo "$session_file" > "$(_super_active_ptr)"
    
    # Build CLI options
    local options=()
    local cli_keys=()
    
    for cli in claude gemini codex kimi; do
      if is_installed "$cli"; then
        options+=("${CLI_ICON[$cli]} ${CLI_LABEL[$cli]}")
        cli_keys+=("$cli")
      fi
    done
    
    [[ ${#options[@]} -eq 0 ]] && die "No CLIs installed."
    [[ ${#options[@]} -eq 1 ]] && { cmd_launch "${cli_keys[0]}" --resume "$session_file"; return; }
    
    ui_banner
    local choice
    choice=$(ui_select_single "Which CLI would you like to resume in?" 0 "${options[@]}")
    
    [[ -z "$choice" ]] && { ui_info "Cancelled."; return; }
    
    cmd_launch "${cli_keys[$choice]}" --resume "$session_file"
  else
    # No input - show session picker
    _pick_session_and_resume
  fi
}

_pick_session_and_resume() {
  local sessions_dir; sessions_dir="$(_super_sessions_dir)"
  
  if [[ ! -d "$sessions_dir" ]] || [[ -z "$(ls "$sessions_dir"/*.md 2>/dev/null)" ]]; then
    ui_warn "No sessions found."
    ui_muted "Run: super launch <cli> to create one"
    return 1
  fi
  
  # Build session list
  local files=()
  local options=()
  local active; active="$(_super_session_file)"
  
  while IFS= read -r f; do
    [[ -f "$f" ]] || continue
    files+=("$f")
    
    local name turns marker cli
    name="$(basename "$f" .md)"
    turns="$(grep -c '^## ' "$f" 2>/dev/null || echo 0)"
    [[ "$f" == "$active" ]] && marker=" ◀ ACTIVE" || marker=""
    
    # Detect CLI from first turn
    local first_turn; first_turn="$(grep -m1 '^## ' "$f" 2>/dev/null || true)"
    cli=""
    [[ "$first_turn" == *"🟠"* ]] && cli="🟠"
    [[ "$first_turn" == *"🔵"* ]] && cli="🔵"
    [[ "$first_turn" == *"🟢"* ]] && cli="🟢"
    [[ "$first_turn" == *"🟡"* ]] && cli="🟡"
    [[ -z "$cli" ]] && cli="⚪"
    
    options+=("$cli $name ($turns turns)$marker")
  done < <(ls -t "$sessions_dir"/*.md 2>/dev/null || true)
  
  [[ ${#options[@]} -eq 0 ]] && { ui_warn "No sessions found."; return 1; }
  
  # Add "New session" option at the end
  options+=("🆕 Start a new session")
  
  ui_banner
  local choice
  choice=$(ui_select_single "Select a session to resume:" 0 "${options[@]}")
  
  [[ -z "$choice" ]] && { ui_info "Cancelled."; return; }
  
  # Check if "new session" selected (last option)
  if [[ "$choice" -eq ${#files[@]} ]]; then
    cmd_menu
    return
  fi
  
  # Resume selected session
  cmd_resume "${files[$choice]}"
}

# ═══════════════════════════════════════════════════════════════════════════════
# SESSIONS COMMAND
# ═══════════════════════════════════════════════════════════════════════════════

cmd_sessions() {
  local sessions_dir; sessions_dir="$(_super_sessions_dir)"
  local active; active="$(_super_session_file)"
  
  if [[ ! -d "$sessions_dir" ]] || [[ -z "$(ls "$sessions_dir"/*.md 2>/dev/null)" ]]; then
    ui_warn "No sessions found."
    ui_muted "Run: super launch <cli> to create one"
    return
  fi
  
  ui_section "Sessions"
  
  local i=1
  while IFS= read -r f; do
    [[ -f "$f" ]] || continue
    local title started turns marker is_active="false"
    title="$(grep '^# Super Session:' "$f" 2>/dev/null | sed 's/# Super Session: //' | head -1 || true)"
    [[ -z "$title" ]] && title="$(basename "$f" .md)"
    started="$(grep '^\*\*Started:\*\*' "$f" 2>/dev/null | sed 's/\*\*Started:\*\* //' | head -1 || true)"
    turns="$(grep -c '^## ' "$f" 2>/dev/null || echo 0)"
    [[ "$f" == "$active" ]] && is_active="true"
    
    # Extract CLI from session
    local cli="unknown"
    local first_turn; first_turn="$(grep -m1 '^## ' "$f" 2>/dev/null || true)"
    [[ "$first_turn" == *"🟠"* ]] && cli="claude"
    [[ "$first_turn" == *"🔵"* ]] && cli="gemini"
    [[ "$first_turn" == *"🟢"* ]] && cli="codex"
    [[ "$first_turn" == *"🟡"* ]] && cli="kimi"
    
    ui_session_line "$i" "$title" "$started" "$turns" "$cli" "$is_active"
    i=$((i + 1))
  done < <(ls -t "$sessions_dir"/*.md 2>/dev/null || true)
  
  ui_spacer
  ui_muted "Run 'super resume <number>' to resume a session"
}

# ═══════════════════════════════════════════════════════════════════════════════
# LOG COMMAND
# ═══════════════════════════════════════════════════════════════════════════════

cmd_log() {
  local arg="${1:-}"
  local session_file
  
  if [[ -z "$arg" ]]; then
    session_file="$(_super_session_file)"
  elif [[ "$arg" =~ ^[0-9]+$ ]]; then
    # Number = last N turns of active session
    session_file="$(_super_session_file)"
    if [[ -n "$session_file" && -f "$session_file" ]]; then
      ui_section "Last $arg turns"
      grep -v '^---$' "$session_file" | tail -n "$((arg * 10))"
      return
    fi
  else
    # Filename
    [[ -f "$arg" ]] || arg="$(_super_sessions_dir)/$arg"
    session_file="$arg"
  fi
  
  [[ -f "$session_file" ]] || die "Session not found: ${1:-active}"
  
  ui_section "Session: $(basename "$session_file")"
  cat "$session_file"
}

