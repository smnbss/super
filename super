# ═══════════════════════════════════════════════════════════════════════════════
# UNINSTALL COMMAND
# ═══════════════════════════════════════════════════════════════════════════════

cmd_uninstall() {
  local root; root="$(_super_find_root)"
  ui_brand "Removing super hooks..."

  _strip_json_hooks() {
    local f="$1" idf="$2"
    [[ -f "$f" ]] || return
    python3 - "$f" "$idf" <<'PYEOF'
import sys, json
path, idf = sys.argv[1], sys.argv[2]
with open(path) as fh: data = json.load(fh)
if "hooks" in data:
    for ev in list(data["hooks"].keys()):
        data["hooks"][ev] = [
            g for g in data["hooks"][ev]
            if not any("super" in h.get(idf,"") for h in g.get("hooks",[]))
        ]
        if not data["hooks"][ev]: del data["hooks"][ev]
with open(path,"w") as fh: json.dump(data,fh,indent=2); fh.write("\n")
PYEOF
    ui_success "Cleaned $f"
  }

  _strip_json_hooks "$root/.claude/settings.json" "command"
  _strip_json_hooks "$root/.gemini/settings.json" "name"
  _strip_json_hooks "$root/.codex/hooks.json"     "command"

  local kf="$root/.kimi/config.toml"
  if [[ -f "$kf" ]]; then
    python3 - "$kf" <<'PYEOF'
import sys, re
with open(sys.argv[1]) as f: c = f.read()
c = re.sub(r'\n# super hooks\n.*?(?=\n\[|\Z)', '', c, flags=re.DOTALL)
with open(sys.argv[1],"w") as f: f.write(c)
PYEOF
    ui_success "Cleaned $kf"
  fi

  session_clear_injections
  ui_spacer
  ui_info "Hooks removed. Sessions preserved at $(_super_sessions_dir)"
}

# ═══════════════════════════════════════════════════════════════════════════════
# MENU COMMAND
# ═══════════════════════════════════════════════════════════════════════════════

cmd_menu() {
  local sessions_dir; sessions_dir="$(_super_sessions_dir)"
  local has_sessions=0
  [[ -d "$sessions_dir" ]] && [[ -n "$(ls "$sessions_dir"/*.md 2>/dev/null)" ]] && has_sessions=1
  
  local active; active="$(_super_session_file)"
  
  # If there's an active session, offer quick continuation
  if [[ -n "$active" && -f "$active" && "$has_sessions" -eq 1 ]]; then
    local turns; turns="$(grep -c '^## ' "$active" 2>/dev/null || echo 0)"
    local name; name="$(basename "$active" .md)"
    
    ui_spacer
    ui_print "  $(_c $UI_SUCCESS)${UI_ICON_ACTIVE}${UI_RESET} $(_c $UI_BOLD)Active:${UI_RESET} $name ($turns turns)"
    ui_spacer
    ui_menu_item "↵" "" "Continue active session" "press Enter"
    ui_menu_item "n" "$UI_ICON_NEW" "Start new session"
    ui_menu_item "r" "$UI_ICON_RESUME" "Resume different session"
    ui_menu_item "s" "" "View status"
    ui_menu_item "d" "" "Run doctor"
    ui_menu_item "q" "" "Quit"
    ui_spacer
    ui_prompt "Choice:"
    read -r choice
    
    case "$choice" in
      ""|↵|1) 
        # Continue with same CLI or ask
        local last_cli; last_cli="$(detect_last_cli)"
        if [[ -n "$last_cli" ]]; then
          cmd_launch "$last_cli" --resume
        else
          cmd_resume
        fi
        ;;
      n|N|new|2) _pick_cli_and_launch ;;
      r|R|resume|3) cmd_resume ;;
      s|S|status|4) print_banner; print_status ;;
      d|D|doctor|5) cmd_doctor ;;
      q|Q|quit) ui_info "Bye!"; exit 0 ;;
      *) cmd_menu ;;
    esac
    return
  fi
  
  # No active session — show standard menu
  ui_spacer
  ui_print "  $(ui_bold "What would you like to do?")"
  ui_spacer
  
  ui_menu_item "1" "$UI_ICON_NEW" "Start a new session"
  if [[ "$has_sessions" -eq 1 ]]; then
    ui_menu_item "2" "$UI_ICON_RESUME" "Resume a previous session"
  fi
  ui_menu_item "d" "" "Run health check (doctor)"
  ui_menu_item "q" "" "Quit"
  ui_spacer
  
  ui_prompt "Choice:"
  read -r choice
  [[ "$choice" == "q" || -z "$choice" ]] && { ui_info "Bye!"; exit 0; }

  case "$choice" in
    1|n|new) _pick_cli_and_launch ;;
    2|r|resume) [[ "$has_sessions" -eq 1 ]] && cmd_resume || die "Invalid choice" ;;
    d|doctor) cmd_doctor ;;
    *) die "Invalid choice: $choice" ;;
  esac
}

# Detect last CLI used in active session
detect_last_cli() {
  local session_file; session_file="$(_super_session_file)"
  [[ -f "$session_file" ]] || return
  
  local last_turn; last_turn="$(grep '^## ' "$session_file" | tail -1)"
  [[ "$last_turn" == *"🟠"* ]] && echo "claude" && return
  [[ "$last_turn" == *"🔵"* ]] && echo "gemini" && return
  [[ "$last_turn" == *"🟢"* ]] && echo "codex" && return
  [[ "$last_turn" == *"🟡"* ]] && echo "kimi" && return
}

# ═══════════════════════════════════════════════════════════════════════════════
# CLI PICKER
# ═══════════════════════════════════════════════════════════════════════════════

_pick_cli_and_launch() {
  local chosen; chosen="$(fzf_pick_cli)"
  [[ "$chosen" == "QUIT" ]] && { ui_info "Bye!"; exit 0; }
  [[ -z "$chosen" ]] && { cmd_menu; return; }
  
  cmd_launch "$chosen"
}

# ═══════════════════════════════════════════════════════════════════════════════
# CONFIG COMMAND
# ═══════════════════════════════════════════════════════════════════════════════

cmd_config() {
  local action="${1:-show}"
  case "$action" in
    show)
      local cfg; cfg="$(_super_find_config)"
      if [[ -f "$cfg" ]]; then
        ui_section "Configuration"
        cat "$cfg"
      else
        ui_warn "No config file found"
        ui_muted "Run: super config init"
      fi
      ;;
    init)
      _super_config_init
      ui_success "Created super.config.yaml"
      ;;
    edit)
      ${EDITOR:-vim} "$(_super_find_config)"
      ;;
    interactive|i)
      cmd_config_interactive
      ;;
    *) die "Usage: super config [show|init|edit|interactive]" ;;
  esac
}

cmd_config_interactive() {
  print_banner
  ui_section "Interactive Configuration"
  
  # Ensure config exists
  local cfg; cfg="$(_super_find_config)"
  [[ -f "$cfg" ]] || _super_config_init
  
  while true; do
    ui_spacer
    ui_print "  $(ui_bold "Configuration Options")"
    ui_spacer
    ui_menu_item "1" "" "Session settings" "cleanup, transcripts"
    ui_menu_item "2" "" "Security settings" "yolo mode, path restrictions"
    ui_menu_item "3" "" "UI settings" "interactive mode"
    ui_menu_item "4" "" "View current config"
    ui_menu_item "5" "" "Edit config in editor"
    ui_menu_item "q" "" "Quit"
    ui_spacer
    ui_prompt "Choice:"
    read -r choice
    
    case "$choice" in
      1) _config_interactive_sessions ;;
      2) _config_interactive_security ;;
      3) _config_interactive_ui ;;
      4) cmd_config show ;;
      5) cmd_config edit ;;
      q|Q) ui_info "Done!"; return ;;
      *) ui_warn "Invalid choice" ;;
    esac
  done
}

_config_interactive_sessions() {
  ui_spacer
  ui_print "  $(ui_bold "Session Settings")"
  ui_spacer
  
  # Get current values
  local cleanup_enabled; cleanup_enabled="$(_super_config_enabled "session.cleanup" && echo "yes" || echo "no")"
  local max_age; max_age="$(_super_session_max_age)"
  [[ -z "$max_age" ]] && max_age="7"
  
  ui_print "  Auto-cleanup: $(_c $([[ "$cleanup_enabled" == "yes" ]] && echo $UI_SUCCESS || echo $UI_MUTED); echo "$cleanup_enabled"${UI_RESET})"
  ui_print "  Max age: $max_age days"
  ui_spacer
  
  ui_menu_item "1" "" "Toggle auto-cleanup"
  ui_menu_item "2" "" "Change max age"
  ui_menu_item "b" "" "Back"
  ui_spacer
  ui_prompt "Choice:"
  read -r subchoice
  
  case "$subchoice" in
    1)
      if [[ "$cleanup_enabled" == "yes" ]]; then
        _super_config_set "session.cleanup" "false"
        ui_success "Auto-cleanup disabled"
      else
        _super_config_set "session.cleanup" "true"
        ui_success "Auto-cleanup enabled"
      fi
      ;;
    2)
      ui_prompt "Enter max age in days (current: $max_age):"
      read -r new_age
      if [[ "$new_age" =~ ^[0-9]+$ ]]; then
        _super_config_set "session.maxAge" "$new_age"
        ui_success "Max age set to $new_age days"
      else
        ui_warn "Invalid number"
      fi
      ;;
    b|B) return ;;
  esac
}

_config_interactive_security() {
  ui_spacer
  ui_print "  $(ui_bold "Security Settings")"
  ui_spacer
  
  # Get current values
  local yolo_enabled; yolo_enabled="$(_super_config_enabled "security.yolo" && echo "yes" || echo "no")"
  
  ui_print "  Yolo mode: $(_c $([[ "$yolo_enabled" == "yes" ]] && echo $UI_WARNING || echo $UI_SUCCESS); echo "$yolo_enabled"${UI_RESET})"
  ui_print "  $(_c $UI_MUTED)(Yolo mode disables confirmation prompts for destructive actions)${UI_RESET}"
  ui_spacer
  
  ui_menu_item "1" "" "Toggle yolo mode"
  ui_menu_item "b" "" "Back"
  ui_spacer
  ui_prompt "Choice:"
  read -r subchoice
  
  case "$subchoice" in
    1)
      if [[ "$yolo_enabled" == "yes" ]]; then
        _super_config_set "security.yolo" "false"
        ui_success "Yolo mode disabled — confirmations enabled"
      else
        ui_warn "Enabling yolo mode — this is dangerous!"
        ui_prompt "Are you sure? (yes/no):"
        read -r confirm
        if [[ "$confirm" == "yes" ]]; then
          _super_config_set "security.yolo" "true"
          ui_success "Yolo mode enabled — no confirmations"
        else
          ui_info "Cancelled"
        fi
      fi
      ;;
    b|B) return ;;
  esac
}

_config_interactive_ui() {
  ui_spacer
  ui_print "  $(ui_bold "UI Settings")"
  ui_spacer
  
  ui_print "  These settings control the super UI behavior"
  ui_spacer
  
  ui_menu_item "1" "" "Initialize config file"
  ui_menu_item "b" "" "Back"
  ui_spacer
  ui_prompt "Choice:"
  read -r subchoice
  
  case "$subchoice" in
    1) cmd_config init ;;
    b|B) return ;;
  esac
}

