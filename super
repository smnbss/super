# ── Skills picker ─────────────────────────────────────────────────────────────

_config_interactive_skills() {
  local entries=() names=() sources=() states=() display=()

  while IFS='|' read -r name source desc enabled; do
    [[ -z "$name" ]] && continue
    names+=("$name")
    sources+=("$source")
    states+=("$enabled")
    local mark="○"; [[ "$enabled" == "true" ]] && mark="◉"
    display+=("$mark $name — $desc")
  done <<< "$(catalog_skills)"

  [[ ${#names[@]} -eq 0 ]] && { ui_warn "No skills in config."; return; }

  display+=("📦 Install enabled skills now")
  display+=("⬅️  Back")

  local choice
  choice=$(ui_select_single "Skills (toggle on/off)" 0 "${display[@]}")
  [[ -z "$choice" ]] && return

  local total=${#names[@]}

  # "Install" option
  if [[ "$choice" -eq $total ]]; then
    ui_brand "Installing enabled skills..."
    ui_spacer
    local i=0
    for name in "${names[@]}"; do
      if [[ "${states[$i]}" == "true" ]]; then
        _catalog_install_skill "$name" "${sources[$i]}" || true
      fi
      i=$((i + 1))
    done
    ui_spacer
    return
  fi

  # "Back" option
  if [[ "$choice" -eq $((total + 1)) ]]; then
    return
  fi

  # Toggle the selected skill
  local idx="$choice"
  local name="${names[$idx]}"
  if [[ "${states[$idx]}" == "true" ]]; then
    _catalog_toggle "skills" "$name" "false"
    ui_info "$name disabled"
  else
    _catalog_toggle "skills" "$name" "true"
    ui_success "$name enabled"
  fi

  # Re-enter to show updated state
  _config_interactive_skills
}

