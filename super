cmd_transcript() {
  local action="${1:-list}"
  local transcript_dir="$(_super_base_dir)/transcripts"
  
  case "$action" in
    list|ls)
      if [[ -d "$transcript_dir" ]]; then
        ui_section "Transcripts"
        ls -la "$transcript_dir"/*.jsonl "$transcript_dir"/*-final.md 2>/dev/null || ui_muted "No transcripts yet"
      else
        ui_warn "No transcripts directory"
      fi
