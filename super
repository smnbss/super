#!/usr/bin/env bash
# super — thin shim that delegates to super.mjs
# Hooks remain bash and source lib/*.sh directly — this shim is only for the CLI.

SUPER_HOME="$(dirname "${BASH_SOURCE[0]}")"

if ! command -v node &>/dev/null; then
  if command -v apt-get &>/dev/null; then
    echo "⚙️  Node.js not found. Installing via apt-get..." >&2
    sudo apt-get update && sudo apt-get install -y nodejs npm >&2
  elif command -v brew &>/dev/null; then
    echo "⚙️  Node.js not found. Installing via brew..." >&2
    brew install node >&2
  else
    echo "🛑 Node.js is not installed." >&2
    echo "   Install it first, e.g.:" >&2
    echo "   sudo apt-get install -y nodejs npm   # Debian/Ubuntu" >&2
    echo "   brew install node                    # macOS" >&2
    exit 1
  fi
fi

# Re-check after attempted install
if ! command -v node &>/dev/null; then
  echo "🛑 Node.js installation failed. Please install manually." >&2
  exit 1
fi

if [[ ! -d "${SUPER_HOME}/node_modules" ]]; then
  if ! command -v npm &>/dev/null; then
    if command -v apt-get &>/dev/null; then
      echo "⚙️  npm not found. Installing via apt-get..." >&2
      sudo apt-get update && sudo apt-get install -y npm >&2
    fi
  fi

  if ! command -v npm &>/dev/null; then
    echo "🛑 npm is not installed (needed to install dependencies)." >&2
    echo "   Install it first, e.g.:" >&2
    echo "   sudo apt-get install -y npm   # Debian/Ubuntu" >&2
    echo "   brew install node             # macOS (includes npm)" >&2
    exit 1
  fi

  echo "⚙️  super dependencies missing. Running npm install in ${SUPER_HOME} ..." >&2
  saved_tty="$(stty -g 2>/dev/null || true)"
  if (cd "${SUPER_HOME}" && npm install); then
    echo "✅ Dependencies installed." >&2
    echo >&2
  else
    echo "🛑 npm install failed. Run \`cd ${SUPER_HOME} && npm install\` manually." >&2
    exit 1
  fi
  [[ -n "$saved_tty" ]] && stty "$saved_tty" 2>/dev/null
fi

exec node "${SUPER_HOME}/super.mjs" "$@"
