{
  "env": {
    "SUPER_HOME": "$SUPER_HOME"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "name": "super-session-start",
            "type": "command",
            "command": "{{SUPER_HOME}}/hooks/gemini/session_start.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "hooks": [
          {
            "name": "super-user-prompt",
            "type": "command",
            "command": "{{SUPER_HOME}}/hooks/gemini/user_prompt.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "run_shell_command|write_file|replace|web_search|edit_file",
        "hooks": [
          {
            "name": "super-after-tool",
            "type": "command",
            "command": "{{SUPER_HOME}}/hooks/gemini/after_tool.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "AfterAgent": [
      {
        "hooks": [
          {
            "name": "super-after-agent",
            "type": "command",
            "command": "{{SUPER_HOME}}/hooks/gemini/after_agent.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "name": "super-stop",
            "type": "command",
            "command": "{{SUPER_HOME}}/hooks/gemini/stop.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
