{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "$SUPER_HOME/hooks/codex/session_start.sh",
            "statusMessage": "super: recording session start",
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$SUPER_HOME/hooks/codex/user_prompt.sh",
            "statusMessage": "super: logging prompt",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$SUPER_HOME/hooks/codex/post_tool_use.sh",
            "statusMessage": "super: logging tool use",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$SUPER_HOME/hooks/codex/stop.sh",
            "statusMessage": "super: logging response",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
