# Append this block to your ~/.kimi/config.toml or project config.toml
# super hooks for Kimi Code CLI

[[hooks]]
event = "SessionStart"
command = "$SUPER_HOME/hooks/kimi/session_start.sh"
timeout = 5000

[[hooks]]
event = "UserPromptSubmit"
command = "$SUPER_HOME/hooks/kimi/user_prompt.sh"
timeout = 5000

[[hooks]]
event = "PostToolUse"
matcher = "shell|bash|run_command|write_file|edit_file|replace|web_search"
command = "$SUPER_HOME/hooks/kimi/post_tool_use.sh"
timeout = 5000

[[hooks]]
event = "Stop"
command = "$SUPER_HOME/hooks/kimi/stop.sh"
timeout = 10000
